# Copy to `.env` in this directory (gitignored). `app.config.init_env()` loads it on startup.
#
# --- Required for live LLM runs ---
# OPENAI_API_KEY=sk-...
#
# --- Models (optional; default in code: app/config.py → DEFAULT_LLM_MODEL) ---
# Global default for all phases unless a per-role override is set:
# SMART_WRITER_MODEL=openai:gpt-4o
# Per phase (decoder, rubric, writer, assessor):
# SMART_WRITER_MODEL_DECODER=openai:gpt-4o-mini
# SMART_WRITER_MODEL_RUBRIC=openai:gpt-4o-mini
# SMART_WRITER_MODEL_WRITER=openai:gpt-4o
# SMART_WRITER_MODEL_ASSESSOR=openai:gpt-4o-mini
# SMART_WRITER_MODEL_PLANNER=openai:gpt-4o-mini
# Optional generation (suffix: DECODER, RUBRIC, PLANNER, WRITER, ASSESSOR, GROUNDING):
# SMART_WRITER_TEMPERATURE_WRITER=0.7
# SMART_WRITER_MAX_TOKENS_WRITER=4096
#
# --- HTTP POST /audit wall-clock limit (0 or unset = no server-side limit) ---
# SMART_WRITER_AUDIT_TIMEOUT_SEC=900
#
# --- LLM transient retries (429 / 5xx / connection errors); see app/llm/retry.py ---
# SMART_WRITER_LLM_RETRY_MAX_ATTEMPTS=5
# SMART_WRITER_LLM_RETRY_BASE_SEC=1
# SMART_WRITER_LLM_RETRY_MAX_SEC=60
#
# --- smart-writer: parallel OpenAI fan-out (rubric + assessor phases) ---
# Lower = fewer overlapping completions = fewer TPM (tokens/minute) rate-limit errors.
# Default is also set in code: app/config.py → DEFAULT_MAX_CONCURRENT_LLM
# and in repo .devcontainer/devcontainer.json → containerEnv (Codespaces).
# Env var name (spelling): SMART_WRITER_MAX_CONCURRENT_LLM
SMART_WRITER_MAX_CONCURRENT_LLM=1
#
# --- Supabase (required for persisting runs/turns; otherwise NullRepo, nothing in DB) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SECRET_KEY=eyJ...   # service role or secret for server-side inserts
#
# --- Canonical library (embeddings + matching; see docs/design-canonical-value-rubric-library.md) ---
# SMART_WRITER_LIBRARY_ENABLED=false
# SMART_WRITER_EMBEDDING_MODEL=text-embedding-3-small
# SMART_WRITER_EMBEDDING_BATCH_SIZE=16
# SMART_WRITER_EMBEDDING_TIMEOUT_SEC=60
# SMART_WRITER_EMBEDDING_ON_FAILURE=skip_library   # or fail_run
# SMART_WRITER_LIBRARY_REFRESH_ANCHORS=true
# SMART_WRITER_LIBRARY_MATCH_THRESHOLD=0.82
# SMART_WRITER_LIBRARY_MATCH_MARGIN=0     # e.g. 0.04 to require top-2 gap among τ-passers; 0 = off
# SMART_WRITER_LIBRARY_MAX_MATCHES=3
# SMART_WRITER_CANONICAL_LIBRARY_PATH=      # optional override; default app/data/canonical_values.json
#
# --- Versioned prompt program (app/prompts/programs/<id>/; see docs/design-versioned-prompt-program.md) ---
# SMART_WRITER_PROMPT_PROGRAM=smart_writer_default
# Optional profile: app/prompts/programs/<program>/profiles/<id>.txt
# SMART_WRITER_PROMPT_PROFILE=
# Per-field defaults (override program defaults; merged with HTTP/CLI prompt_parameters):
# SMART_WRITER_PROMPT_AUDIENCE=
# SMART_WRITER_PROMPT_WRITING_REGISTER=
# SMART_WRITER_PROMPT_LENGTH_TARGET=
# SMART_WRITER_PROMPT_RISK_TOLERANCE=
# SMART_WRITER_PROMPT_FORMALITY=
#
# --- Research / document planning (after rubrics; see docs/design-research-planning-phase.md) ---
# Default when profile is omitted from manifest [research_planning.profile_defaults]: on (true).
# SMART_WRITER_RESEARCH_PLANNING_DEFAULT=true
# Skip planning for very short prompts without reference (chars): default 200
# SMART_WRITER_PLANNING_MIN_CHARS=200
#
# --- Optional ---
# LOGFIRE_TOKEN=
